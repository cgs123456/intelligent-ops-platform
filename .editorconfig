# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.py]
indent_size = 4
# Python 项目使用 UTF-8 无 BOM
charset = utf-8

[*.{html,css,js}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{toml,ini,cfg}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # Markdown 末尾两空格表示换行

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2

[*.json]
indent_size = 2
