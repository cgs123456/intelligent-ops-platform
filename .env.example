# ===================================================================
# 智能运营平台 .env 示例
# 同步自 config.py，复制为 .env 后按实际环境填写
# ===================================================================

# ========== 必须设置（生产环境）==========
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# PostgreSQL 数据库密码（生产环境必填，docker-compose.prod.yml 会强制校验）
DB_PASSWORD=

# ========== Flask 环境 ==========
# development / production
FLASK_ENV=development
FLASK_DEBUG=0

# ========== 数据库 ==========
# 开发默认 SQLite；生产必须用 PostgreSQL
DATABASE_URL=postgresql://ops:change_me@db:5432/ops_platform

# ========== Redis / 缓存 ==========
CACHE_TYPE=redis
CACHE_REDIS_URL=redis://redis:6379/0
# 缓存默认过期时间（秒）
CACHE_DEFAULT_TIMEOUT=3600
# 限流存储（Flask-Limiter 读取 RATELIMIT_STORAGE_URL）
RATELIMIT_STORAGE_URL=redis://redis:6379/1
# 全局默认限流（每小时）
RATELIMIT_DEFAULT=200/hour
# 登录接口限流（每分钟）
RATELIMIT_AUTH=10/minute

# ========== CORS ==========
# 生产环境必须显式指定允许的源，缺失则 docker-compose 启动失败
CORS_ORIGINS=https://ops.example.com,https://admin.example.com

# ========== 认证 / RBAC ==========
# 1=开启 RBAC 权限校验（生产强制为 1），0=dev demo 模式
RBAC_ENABLED=1

# ========== LLM（AIGC 模块可选）==========
# rule=规则引擎（默认，无需 API Key）；glm=智谱 GLM；qwen=通义千问
LLM_PROVIDER=rule
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=glm-4-flash

# ========== RPA 调度 ==========
# 1=启用 RPA 定时任务
RPA_SCHEDULE_ENABLED=0
# 报价采集 cron（默认每日 09:00）
RPA_QUOTE_CRON=0 9 * * *
# 订单同步 cron（默认每 30 分钟）
RPA_SYNC_CRON=*/30 * * * *
# 最大重试次数
RPA_MAX_RETRY=3
# 指数退避基数（秒）
RPA_RETRY_BACKOFF=2.0

# ========== FDE / ETL ==========
# 1=增量拉取
FDE_INCREMENTAL=1
# 1=数据质量强校验
FDE_DQ_STRICT=1

# ========== 闭环自动化 ==========
# 单步超时秒数
LOOP_TIMEOUT=60
# 1=低库存自动触发闭环
LOOP_AUTO_TRIGGER=0

# ========== 监控 / API 文档 ==========
# 1=启用 Prometheus 指标 /metrics
METRICS_ENABLED=1
# 1=启用 Swagger 文档 /docs/swagger
API_DOCS_ENABLED=0

# ========== Gunicorn（容器内运行参数）==========
# worker 数量，默认 = CPU*2+1
GUNICORN_WORKERS=5
# 日志级别：debug / info / warning / error
GUNICORN_LOG_LEVEL=info

# ========== 备份调度 ==========
# 备份 cron 表达式（默认每天 02:00）
BACKUP_CRON=0 2 * * *
# 备份保留天数（默认 7 天）
BACKUP_RETENTION_DAYS=7

# ========== RPA / LLM 后端选择 ==========
# RPA 适配器后端：mock=模拟（默认）/ selenium=Selenium 真实驱动
RPA_BACKEND=mock
# LLM 适配器后端类型（与 LLM_PROVIDER 一致）：rule / glm / qwen / openai

# ========== 告警通知（可选）==========
# 钉钉机器人 webhook（留空则不发送）
ALERT_DINGTALK_WEBHOOK=
# 企业微信机器人 webhook（留空则不发送）
ALERT_WECOM_WEBHOOK=
# 邮件告警（SMTP 配置全部留空则不发送）
ALERT_MAIL_TO=
ALERT_MAIL_SMTP_HOST=
ALERT_MAIL_SMTP_PORT=465
ALERT_MAIL_SMTP_USER=
ALERT_MAIL_SMTP_PASS=
ALERT_MAIL_FROM=ops-platform-alert@local

# ========== Celery（可选，异步任务）==========
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
